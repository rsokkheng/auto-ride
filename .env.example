APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auto_ride_db
DB_USERNAME=root
DB_PASSWORD=npca@123

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google Maps (optional — leave blank to use Haversine distance calculation)
GOOGLE_MAPS_API_KEY=

# Driver matching algorithm
DRIVER_MATCH_RADIUS_KM=30
DRIVER_MATCH_DISTANCE_WEIGHT=0.7
DRIVER_MATCH_RATING_WEIGHT=1.5

# Delivery fee pricing (KHR ៛)
DELIVERY_FEE_BASE=3000
DELIVERY_FEE_PER_KM=1200
DELIVERY_FEE_SURCHARGE_SMALL=0
DELIVERY_FEE_SURCHARGE_MEDIUM=2000
DELIVERY_FEE_SURCHARGE_LARGE=5000

# Commission rates (%)
COMMISSION_RATE_OWNER=20
COMMISSION_RATE_RENTAL=20
COMMISSION_RATE_EMPLOYEE=10
COMMISSION_RENTAL_COMPANY=10
COMMISSION_EMPLOYEE_COMPANY=90

# Ride fare pricing (KHR ៛)
RIDE_FARE_BASE_STANDARD=4000
RIDE_FARE_PERKM_STANDARD=1500
RIDE_FARE_BASE_PREMIUM=8000
RIDE_FARE_PERKM_PREMIUM=3000
RIDE_FARE_BASE_SHARED=2500
RIDE_FARE_PERKM_SHARED=1000
